# Copy this file to one of: .env.local | .env.dev | .env.prod (all gitignored).
# A plain `.env` file is not loaded unless you point FRANCHISE_DOTENV_PATH at it.
#
# Pick which file loads when starting the API (shell only, before Python):
#   FRANCHISE_DOTENV=local   -> .env.local  (default)
#   FRANCHISE_DOTENV=dev     -> .env.dev
#   FRANCHISE_DOTENV=prod    -> .env.prod
# Or: FRANCHISE_DOTENV_PATH=/absolute/path/to/file.env
#
# Example:
#   FRANCHISE_DOTENV=dev uvicorn apps.api.src.main:app --reload

APP_ENV=development
API_PREFIX=/api/v1
BOOTSTRAP_ADMIN_SECRET=change-bootstrap-secret
JWT_SECRET_KEY=replace-this-with-a-strong-jwt-secret-key-of-at-least-32-characters

# Local PostgreSQL example (user yash, no password in URL)
DATABASE_URL=postgresql+psycopg://yash@127.0.0.1:5432/franchise_billing

# Remote (e.g. Supabase): if the password contains @ # : / ? & etc., you MUST
# percent-encode those characters in the password part only. Example: secret@x -> secret%40x
# DATABASE_URL=postgresql+psycopg://postgres:secret%40x@db.xxxx.supabase.co:5432/postgres?sslmode=require

# PostgreSQL example with password
# DATABASE_URL=postgresql+psycopg://postgres:your_password@127.0.0.1:5432/franchise_billing
