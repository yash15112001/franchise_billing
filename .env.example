# Copy to `.env` in the repo root (gitignored). Only uncommented KEY=value lines apply.
# You can keep local + Supabase + production examples below; switch by commenting
# one block and uncommenting another. For deployment, set the same variables in
# Railway / the host instead of committing `.env`.

# --- Shared (always set these for the environment you are running) ---
APP_ENV=development
API_PREFIX=/api/v1
BOOTSTRAP_ADMIN_SECRET=change-bootstrap-secret-min-32-chars-long
JWT_SECRET_KEY=replace-this-with-a-strong-jwt-secret-key-of-at-least-32-characters

# --- Database: use ONE active DATABASE_URL (comment the others) ---

# Local PostgreSQL
DATABASE_URL=postgresql+psycopg://yash@127.0.0.1:5432/franchise_billing

# Supabase / cloud (encode @ in password as %40)
# DATABASE_URL=postgresql+psycopg://postgres:secret%40here@db.xxxx.supabase.co:5432/postgres?sslmode=require

# With DB password locally
# DATABASE_URL=postgresql+psycopg://postgres:your_password@127.0.0.1:5432/franchise_billing
